# Test artifacts
test-logs-*/
test-results-*.txt

# Auto-generated scene detection metadata
*.scenes.json

# Raw/intermediate video files from recording
*-raw.mp4
*-original.mp4
# Build artifacts
.goose-bin/

# Per-scenario recording cache
.alert-cache.json

# Runtime backups created by run.sh (restored by cleanup.sh)
.approval-rego-backup

# User-specific LLM credentials (example templates are tracked)
my-llm-credentials.yaml

# Golden transcripts (captured by capture-eval.sh, may contain sensitive data)
golden-transcripts/

# Python bytecode
__pycache__/

# Overnight validation logs and results
overnight-logs-*/
overnight-logs-*.log
overnight-results-*.txt
overnight-rerun-launcher-*.log
nohup-*.log

# Secrets (tracked via sealed-secrets or external vault)
base/secrets/

# OS files
.DS_Store
