# Test artifacts
test-logs-*/
test-results-*.txt

# Auto-generated scene detection metadata
*.scenes.json

# Raw/intermediate video files from recording
*-raw.mp4
*-original.mp4
# Build artifacts
.goose-bin/

# Per-scenario recording cache
.alert-cache.json

# Runtime backups created by run.sh (restored by cleanup.sh)
.approval-rego-backup

# User-specific LLM credentials (example templates are tracked)
my-llm-credentials.yaml

# Golden transcript archives (version-specific snapshots, large)
golden-transcripts/archive/

# Python bytecode
__pycache__/

# Overnight validation logs and results
overnight-logs-*/
overnight-logs-*.log
overnight-results-*.txt
overnight-rerun-launcher-*.log
nohup-*.log

# Ad-hoc run/rerun/retest logs and result directories
/*-run.log
/*-retest*.log
/*-rerun*.log
/*-test*.log
/*-final.log
/overnight-*.log
/rerun-*.log
parallel-results-*/
parallel-*-run*.log
parallel-run-*.log
rerun-logs-*/
rerun-output.log
rerun-failed.log
redeploy-*/
sequential-retest-*/

# One-off runner scripts (use scripts/overnight-ocp-validation.sh instead)
/rerun-*.sh
/run-preflight-validation.sh
/run-new-v14-scenarios.sh
/run-sequential-retest.sh

# Stale watch/debug artifacts
scenarios/*/watch_*

# Secrets (tracked via sealed-secrets or external vault)
base/secrets/

# OS files
.DS_Store
